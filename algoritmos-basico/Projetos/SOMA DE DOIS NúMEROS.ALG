Algoritmo "Soma de dois nśmeros"
// Disciplina   : Algoritmos e Programaēćo
// Professor   : Esteban Orellana
// Descriēćo   : Soma dois nśmeros A e B
// Autor(a)    : Renato Justino
// Data atual  : 8/20/2025
Var
SOMA, NUMA, NUMB: inteiro

Inicio
escreval("Digite os nśmeros: ")
leia(NUMA)
leia(NUMB)
SOMA <- NUMA  + NUMB
escreval(SOMA)
Fimalgoritmo